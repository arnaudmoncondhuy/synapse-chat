{#
    Synapse Chat Component (Minimalist Organic Design)
    
    ═══════════════════════════════════════════════════════════════════════════
    VARIABLES DISPONIBLES
    ═══════════════════════════════════════════════════════════════════════════
    
    @param array history (optionnel, défaut: [])
        Historique des messages. Format: [{'role': 'user'|'assistant', 'content': string}]
    
    @param string controller_override (optionnel, défaut: 'synapse-chat')
        Nom du controller Stimulus custom
    
    @param array attr (optionnel, défaut: {})
        Attributs HTML supplémentaires pour le conteneur
    
    @param bool allow_new_chat (optionnel, défaut: true)
        Afficher le bouton "Nouvelle conversation"
    
    ═══════════════════════════════════════════════════════════════════════════
    EXEMPLES D'USAGE
    ═══════════════════════════════════════════════════════════════════════════
    
    Intégration dans un layout existant :
    {{ include('@Synapse/chat/component.html.twig') }}
    
    ═══════════════════════════════════════════════════════════════════════════
#}

{# Link the CSS (AssetMapper) #}
<link rel="stylesheet" href="{{ asset('synapse-chat/styles/synapse_chat.css') }}">

{% set history = history|default([]) %}
{% set controller_override = controller_override|default('synapse-chat') %}
{% set attr = attr|default({}) %}
{% set allow_new_chat = allow_new_chat|default(true) %}
{% set mode_class = history is empty ? 'synapse-chat-mode-welcome' : 'synapse-chat-mode-active' %}
{% set currentConversationId = currentConversationId|default(app.request.query.get('conversation')) %}

<div class="synapse-chat-layout {{ mode_class }}"
     data-controller="{{ controller_override }}"
     data-{{ controller_override }}-chat-url-value="{{ path('synapse_api_chat') }}"
     data-{{ controller_override }}-api-url-value="{{ path('synapse_api_chat') }}"
     data-{{ controller_override }}-reset-url-value="{{ path('synapse_api_reset') }}"
     data-{{ controller_override }}-csrf-url-value="{{ path('synapse_api_csrf_token') }}"
     data-{{ controller_override }}-memory-confirm-url-value="{{ path('synapse_api_memory_confirm') }}"
     data-{{ controller_override }}-memory-reject-url-value="{{ path('synapse_api_memory_reject') }}"
     data-{{ controller_override }}-memory-list-url-value="{{ path('synapse_api_memory_list') }}"
     data-{{ controller_override }}-memory-delete-url-template-value="{{ path('synapse_api_memory_delete', {'id': 'MEMORY_ID'}) }}"
     data-{{ controller_override }}-memory-manual-url-value="{{ path('synapse_api_memory_create_manual') }}"
     data-{{ controller_override }}-memory-update-url-template-value="{{ path('synapse_api_memory_update', {'id': 'MEMORY_ID'}) }}"
     data-{{ controller_override }}-conversations-url-value="{{ path('synapse_api_conversations_list') }}"
     data-{{ controller_override }}-current-conversation-id-value="{{ currentConversationId }}"
     data-{{ controller_override }}-debug-url-template-value="{{ path('synapse_debug_show', {'id': 'DEBUG_ID'}) }}"
     data-{{ controller_override }}-debug-value="{{ (debug_mode|default(false) and synapse_can_debug()) ? 'true' : 'false' }}"
     data-{{ controller_override }}-stateless-value="{{ app.request.query.get('stateless', false) ? 'true' : 'false' }}"
     data-{{ controller_override }}-supports-vision-value="{{ synapse_active_model_supports('vision') ? 'true' : 'false' }}"
     data-csrf-token="{{ csrf_token('synapse_api') }}"
     {% for k, v in attr|default({}) %} {{ k }}="{{ v|e('html_attr') }}"{% endfor %}>

    {# Overlay Mobile pour la Sidebar #}
    <div class="synapse-chat-sidebar-overlay" data-{{ controller_override }}-target="sidebarOverlay" data-action="click->{{ controller_override }}#closeSidebar"></div>

    {# ── COLONNE GAUCHE : HISTORIQUE ───────────────────────────────────────── #}
    <aside class="synapse-chat-sidebar" data-{{ controller_override }}-target="sidebar">
        <div class="synapse-chat-sidebar__header">
            <div class="synapse-chat-tabs">
                <button class="synapse-chat-tab active" data-{{ controller_override }}-target="tabConversations" data-action="click->{{ controller_override }}#showConversationsTab">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                    Discussions
                </button>
                <button class="synapse-chat-tab" data-{{ controller_override }}-target="tabMemory" data-action="click->{{ controller_override }}#showMemoryTab">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path></svg>
                    Mémoire
                </button>
            </div>
            <button class="synapse-chat-sidebar__close synapse-btn-small" data-action="click->{{ controller_override }}#closeSidebar" aria-label="Fermer le menu">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>

        <div class="synapse-chat-sidebar__content">
            <!-- Onglet Conversations -->
            <div class="synapse-chat-tab-panel active" data-{{ controller_override }}-target="panelConversations">
                <div class="synapse-chat-sidebar__list" data-{{ controller_override }}-target="conversationsList">
                    {# Liste injectée dynamiquement par le JS #}
                    <div class="synapse-chat-sidebar__loading">Chargement...</div>
                </div>
                
                <div class="synapse-chat-sidebar__empty synapse-hidden" data-{{ controller_override }}-target="conversationsEmpty">
                    <p>Aucune conversation</p>
                </div>
            </div>

            <!-- Onglet Mémoire -->
            <div class="synapse-chat-tab-panel synapse-hidden" data-{{ controller_override }}-target="panelMemory">
                <form class="synapse-memory-add-form" data-action="submit->{{ controller_override }}#addMemory">
                    <div class="synapse-memory-input-wrapper">
                        <input type="text" data-{{ controller_override }}-target="memoryInput" placeholder="Nouveau fait à retenir..." class="synapse-memory-input" required>
                        <button type="submit" class="synapse-memory-submit" title="Ajouter à la mémoire">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                        </button>
                    </div>
                </form>

                <div class="synapse-chat-sidebar__list" data-{{ controller_override }}-target="memoryList">
                    {# Liste des souvenirs injectée par JS #}
                    <div class="synapse-chat-sidebar__loading">Chargement...</div>
                </div>

                <div class="synapse-chat-sidebar__empty synapse-hidden" data-{{ controller_override }}-target="memoryEmpty">
                    <p>Aucun souvenir retenu</p>
                </div>
            </div>
        </div>

        {% if allow_new_chat %}
        <div class="synapse-chat-sidebar__footer">
            <button class="synapse-chat-btn synapse-chat-btn--primary synapse-chat-btn--full" data-action="click->{{ controller_override }}#newConversation">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Nouvelle conversation
            </button>
        </div>
        {% endif %}
    </aside>

    {# ── COLONNE CENTRALE : CHAT ───────────────────────────────────────────── #}
    <main class="synapse-chat-main">
        
        {# Header Mobile (Visible uniquement sur petits écrans) #}
        <header class="synapse-chat-main__header">
            <button class="synapse-chat-btn synapse-chat-btn--icon synapse-chat-sidebar-toggle" data-action="click->{{ controller_override }}#toggleSidebar" aria-label="Ouvrir le menu">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
            </button>
            <span class="synapse-chat-main__title">Synapse AI</span>
            <div class="synapse-chat-main__header-spacer"></div>
        </header>

        <div class="synapse-chat-messages" data-{{ controller_override }}-target="messages">
            
            {# État d'accueil (Nouvelle discussion) #}
            <div class="synapse-chat-greeting {{ history is not empty ? 'synapse-hidden' : '' }}" data-{{ controller_override }}-target="greeting">
                {% block synapse_greeting_content %}
                    <div class="synapse-chat-greeting__avatar">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
                    </div>
                    <h1 class="synapse-chat-greeting__title">Bonjour</h1>
                    <p class="synapse-chat-greeting__subtitle">Comment puis-je vous aider aujourd'hui ?</p>
                {% endblock %}
            </div>

            {# Boucle de l'historique #}
            {% for msg in history %}
                {% set metadata = msg.metadata|default({}) %}
                {% if metadata.subtype|default('') == 'system_action' %}
                    <div class="synapse-chat-message synapse-chat-message--system-action">
                        <div class="synapse-chat-message__system-content">
                            {{ msg.decryptedContent|default(msg.content)|synapse_markdown }}
                        </div>
                    </div>
                {% else %}
                    {% set is_ai = msg.role == 'assistant' or msg.role == 'model' or msg.role == 'MODEL' %}
                    <div class="synapse-chat-message synapse-chat-message--{{ is_ai ? 'assistant' : 'user' }}">
                        {% if is_ai %}
                            <div class="synapse-chat-avatar synapse-chat-avatar--ai">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
                            </div>
                        {% endif %}
                        
                        <div class="synapse-chat-message__content">
                            <div class="synapse-chat-bubble">
                                {# Afficher les images depuis les pièces jointes #}
                                {% if not is_ai and msg.attachments is defined and msg.attachments is not empty %}
                                    <div class="synapse-chat-message-images">
                                        {% for att in msg.attachments %}
                                            <img src="{{ path('synapse_attachment_serve', {uuid: att.uuid}) }}" alt="Image attachée">
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {% set displayContent = msg.decryptedContent is defined ? msg.decryptedContent : (msg.content is defined ? msg.content : '') %}
                                {{ displayContent|synapse_markdown }}
                            </div>
                            {% if is_ai and debug_mode|default(false) and synapse_can_debug() and msg.metadata.debug_id is defined %}
                                <button type="button" class="synapse-chat-debug-btn" data-action="click->{{ controller_override }}#showDebug" data-debug-id="{{ msg.metadata.debug_id }}" title="Voir le debug">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bug"><path d="m8 2 1.88 1.88"/><path d="M14.12 3.88 16 2"/><path d="M9 7.13v-1a3.003 3.003 0 1 1 6 0v1"/><path d="M12 20c-3.3 0-6-2.7-6-6v-3a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v3c0 3.3-2.7 6-6 6"/><path d="M12 20v-9"/><path d="M6.53 9C4.6 8.8 3 7.1 3 5"/><path d="M6 13H2"/><path d="M3 21c0-2.1 1.7-3.9 3.8-4"/><path d="M20.97 5c0 2.1-1.6 3.8-3.5 4"/><path d="M22 13h-4"/><path d="M17.2 17c2.1.1 3.8 1.9 3.8 4"/></svg>
                                </button>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>

        {# Zone de saisie (fixée en bas de la zone centrale) #}
        <div class="synapse-chat-input-area">
            <form class="synapse-chat-form" data-action="submit->{{ controller_override }}#send" id="chat-form">
                <div class="synapse-chat-input-wrapper">
                    {# Zone de preview des images attachées #}
                    <div class="synapse-chat-image-preview synapse-hidden" data-{{ controller_override }}-target="imagePreview"></div>
                    <textarea 
                        class="synapse-chat-textarea"
                        data-{{ controller_override }}-target="input" 
                        placeholder="Posez votre question ou saisissez un prompt..." 
                        rows="1"
                        aria-label="Message explicatif"></textarea>

                    <div class="synapse-chat-toolbar">
                        <div class="synapse-chat-toolbar__left">
                            {# Bouton d'attache d'image (visible uniquement si le modèle supporte la vision) #}
                            {% if synapse_active_model_supports('vision') %}
                                <button type="button" class="synapse-chat-btn-attach" data-action="click->{{ controller_override }}#attachImage" data-{{ controller_override }}-target="attachBtn" aria-label="Joindre une image" title="Joindre une image">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                </button>
                                <input type="file" accept="image/jpeg,image/png,image/webp,image/gif" multiple class="synapse-hidden" data-{{ controller_override }}-target="fileInput" data-action="change->{{ controller_override }}#handleFileInput">
                            {% endif %}
                            {% set agents = synapse_get_agents() %}
                            {% if agents is not empty %}
                                <div class="synapse-chat-tone-picker" data-{{ controller_override }}-target="agentPicker">
                                    <button type="button" class="synapse-chat-tone-trigger" data-action="click->{{ controller_override }}#toggleAgentMenu" data-{{ controller_override }}-target="agentTrigger" aria-label="Choisir un agent">
                                        <span class="synapse-chat-tone-trigger__emoji" data-{{ controller_override }}-target="currentAgentEmoji">🤖</span>
                                        <span class="synapse-chat-tone-trigger__name" data-{{ controller_override }}-target="currentAgentName">Agent</span>
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                                    </button>

                                    <div class="synapse-chat-tone-menu synapse-hidden" data-{{ controller_override }}-target="agentMenu">
                                        <div class="synapse-chat-tone-menu__notice">
                                            L'agent définit le rôle, le contexte et les outils disponibles pour cette conversation.
                                        </div>
                                        <div class="synapse-chat-tone-option active" data-action="click->{{ controller_override }}#selectAgent" data-agent-key="" data-agent-name="Agent" data-agent-emoji="🤖">
                                            <span class="synapse-chat-tone-option__emoji">🤖</span>
                                            <div class="synapse-chat-tone-option__info">
                                                <div class="synapse-chat-tone-option__name">Aucun agent (Par défaut)</div>
                                            </div>
                                        </div>
                                        {% for a in agents %}
                                            <div class="synapse-chat-tone-option" data-action="click->{{ controller_override }}#selectAgent" data-agent-key="{{ a.key }}" data-agent-name="{{ a.name }}" data-agent-emoji="{{ a.emoji }}">
                                                <span class="synapse-chat-tone-option__emoji">{{ a.emoji }}</span>
                                                <div class="synapse-chat-tone-option__info">
                                                    <div class="synapse-chat-tone-option__name">{{ a.name }}</div>
                                                    <div class="synapse-chat-tone-option__desc">{{ a.description }}</div>
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                    <input type="hidden" name="agent" value="" data-{{ controller_override }}-target="agentInput">
                                </div>
                            {% endif %}
                            {% set tones = synapse_get_tones() %}
                            {% if tones is not empty %}
                                <div class="synapse-chat-tone-picker" data-{{ controller_override }}-target="tonePicker">
                                    <button type="button" class="synapse-chat-tone-trigger" data-action="click->{{ controller_override }}#toggleToneMenu" data-{{ controller_override }}-target="toneTrigger" aria-label="Choisir une personnalité">
                                        <span class="synapse-chat-tone-trigger__emoji" data-{{ controller_override }}-target="currentToneEmoji">✨</span>
                                        <span class="synapse-chat-tone-trigger__name" data-{{ controller_override }}-target="currentToneName">Personnalité</span>
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                                    </button>

                                    <div class="synapse-chat-tone-menu synapse-hidden" data-{{ controller_override }}-target="toneMenu">
                                        <div class="synapse-chat-tone-menu__notice">
                                            Le ton modifie uniquement le style de la réponse, pas la capacité de réflexion de l'IA.
                                        </div>
                                        <div class="synapse-chat-tone-option active" data-action="click->{{ controller_override }}#selectTone" data-tone-key="" data-tone-name="Personnalité" data-tone-emoji="✨">
                                            <span class="synapse-chat-tone-option__emoji">✨</span>
                                            <div class="synapse-chat-tone-option__info">
                                                <div class="synapse-chat-tone-option__name">Normal (Par défaut)</div>
                                            </div>
                                        </div>
                                        {% for t in tones %}
                                            <div class="synapse-chat-tone-option" data-action="click->{{ controller_override }}#selectTone" data-tone-key="{{ t.key }}" data-tone-name="{{ t.name }}" data-tone-emoji="{{ t.emoji }}">
                                                <span class="synapse-chat-tone-option__emoji">{{ t.emoji }}</span>
                                                <div class="synapse-chat-tone-option__info">
                                                    <div class="synapse-chat-tone-option__name">{{ t.name }}</div>
                                                    <div class="synapse-chat-tone-option__desc">{{ t.description }}</div>
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                    <input type="hidden" name="tone" value="" data-{{ controller_override }}-target="toneInput">
                                </div>
                            {% endif %}
                        </div>

                        <div class="synapse-chat-toolbar__right">
                            <button type="submit" class="synapse-chat-btn-send" data-{{ controller_override }}-target="submitBtn" aria-label="Envoyer">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                            </button>
                        </div>
                    </div>
                </div>
                
                <div class="synapse-chat-disclaimer">
                    L'IA peut générer des informations incorrectes. Vérifiez les faits importants.
                </div>
            </form>
        </div>
    </main>
    
    {# ── COLONNE DROITE : PLACEHOLDER ──────────────────────────────────────── #}
    <aside class="synapse-chat-aside" data-{{ controller_override }}-target="aside">
        {# Utilisable pour l'historique de recherche, réglages additionnels, ou contexte #}
    </aside>

</div>
