<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Assistant IA | Synapse{% endblock %}</title>
    
    <style>
        /* Base styles for standalone page */
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            font-family: system-ui, -apple-system, sans-serif;
        }
    </style>
    
    {% block stylesheets %}{% endblock %}
    
    {% block importmap %}
        {{ importmap('app') }}
    {% endblock %}
</head>
<body>
    {# 
       On inclut le composant fluide. 
       Il prendra automatiquement tout l'espace disponible (100vh grâce au CSS du body ci-dessus) 
    #}
    {{ include('@Synapse/chat/component_new.html.twig') }}

    {% block javascripts %}{% endblock %}
</body>
</html>
