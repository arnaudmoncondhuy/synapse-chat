<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token('synapse_api') }}">
    
    <title>{% block chat_title %}Assistant IA | Synapse{% endblock %}</title>
    
    <style>
        /* Base styles for standalone page - Minimalist Organic */
        body, html {
            margin: 0;
            padding: 0;
            width: 100vw;
            height: 100vh;
            overflow: hidden;
            background-color: #ffffff;
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }
        
        .synapse-chat-v2-wrapper {
            width: 100%;
            height: 100%;
        }
    </style>
    
    {% block chat_stylesheets %}{% endblock %}
    
    {% block chat_importmap %}
        {{ importmap('app') }}
    {% endblock %}
</head>
<body>
    <div class="synapse-chat-v2-wrapper">
        {{ include('@Synapse/chat/component_new.html.twig', {
            'debug_mode': debug_mode|default(false)
        }) }}
    </div>

    {% block chat_scripts %}{% endblock %}
</body>
</html>
